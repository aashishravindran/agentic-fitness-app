# ── Chat ─────────────────────────────────────────────────────────────────

def cmd_chat(args: argparse.Namespace) -> None:
    user_id = resolve_user(args)
    message = args.message
    data = api("POST", f"{get_base_url(args)}/api/users/{user_id}/workout",
               {"prompt": message})
    # If the supervisor routed to QA, chat_response is in state
    state = data.get("state", {})
    chat = state.get("chat_response") or data.get("chat_response")
    if chat:
        console.print(Panel(chat, title="Max", border_style="cyan"))
    else:
        # Supervisor generated a workout instead of chatting
        print_workout(data, args)


# ── Argparse setup ───────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="superset",
        description="SuperSet CLI — AWS CLI-style client for the SuperSet Fitness API",
    )
    parser.add_argument("--url", help="Backend URL (default: from config or http://localhost:8000)")
    parser.add_argument("--json", dest="json_output", action="store_true", help="Output raw JSON")

    sub = parser.add_subparsers(dest="command")

    # health
    sub.add_parser("health", help="Check backend health")

    # help
    sub.add_parser("help", help="Show all API endpoints")

    # configure
    p_cfg = sub.add_parser("configure", help="Set default URL and user")
    p_cfg.add_argument("--url", dest="url", help="Backend URL")
    p_cfg.add_argument("--user", help="Default user ID")

    # ── users ────────────────────────────────────────────────────────
    p_users = sub.add_parser("users", help="User management")
    users_sub = p_users.add_subparsers(dest="action")

    p_intake = users_sub.add_parser("intake", help="Onboard user")
    p_intake.add_argument("user_id", nargs="?", help="User ID")
    p_intake.add_argument("--fitness-level", default="Intermediate")
    p_intake.add_argument("--about-me", help="Free-text about the user")
    p_intake.add_argument("--equipment", help="Comma-separated equipment list")
    p_intake.add_argument("--height", type=float, help="Height in cm")
    p_intake.add_argument("--weight", type=float, help="Weight in kg")

    p_refine = users_sub.add_parser("refine", help="Refine recommendation")
    p_refine.add_argument("user_id", nargs="?", help="User ID")
    p_refine.add_argument("--feedback", required=True, help="Feedback text")

    p_accept = users_sub.add_parser("accept", help="Accept recommendation")
    p_accept.add_argument("user_id", nargs="?", help="User ID")

    p_select = users_sub.add_parser("select", help="Select personas manually")
    p_select.add_argument("user_id", nargs="?", help="User ID")
    p_select.add_argument("--personas", required=True, help="Comma-separated persona list")

    p_profile = users_sub.add_parser("profile", help="Get user profile")
    p_profile.add_argument("user_id", nargs="?", help="User ID")

    p_status = users_sub.add_parser("status", help="Get weekly status")
    p_status.add_argument("user_id", nargs="?", help="User ID")

    p_settings = users_sub.add_parser("settings", help="Update settings")
    p_settings.add_argument("user_id", nargs="?", help="User ID")
    p_settings.add_argument("--max-workouts", type=int, help="Max workouts per week")
    p_settings.add_argument("--threshold", type=float, help="Fatigue threshold (0.0-1.0)")
    p_settings.add_argument("--duration", type=int, help="Workout duration in minutes")
    p_settings.add_argument("--equipment", help="Comma-separated equipment list")
    p_settings.add_argument("--about-me", help="About me text")

    # ── workout ──────────────────────────────────────────────────────
    p_workout = sub.add_parser("workout", help="Workout management")
    workout_sub = p_workout.add_subparsers(dest="action")

    p_gen = workout_sub.add_parser("generate", help="Generate a workout")
    p_gen.add_argument("user_id", nargs="?", help="User ID")
    p_gen.add_argument("--prompt", required=True, help="Workout request")
    p_gen.add_argument("--goal", help="Override goal")

    p_log = workout_sub.add_parser("log-set", help="Log a set")
    p_log.add_argument("user_id", nargs="?", help="User ID")
    p_log.add_argument("--exercise", help="Exercise name")
    p_log.add_argument("--exercise-id", help="Exercise ID")
    p_log.add_argument("--weight", type=float, required=True, help="Weight")
    p_log.add_argument("--reps", type=int, required=True, help="Reps")
    p_log.add_argument("--rpe", type=int, default=5, help="RPE (1-10)")

    p_finish = workout_sub.add_parser("finish", help="Finish workout")
    p_finish.add_argument("user_id", nargs="?", help="User ID")

    p_hist = workout_sub.add_parser("history", help="Get workout history")
    p_hist.add_argument("user_id", nargs="?", help="User ID")

    # ── reset ────────────────────────────────────────────────────────
    p_reset = sub.add_parser("reset", help="Reset operations")
    reset_sub = p_reset.add_subparsers(dest="action")

    p_rf = reset_sub.add_parser("fatigue", help="Reset fatigue scores")
    p_rf.add_argument("user_id", nargs="?", help="User ID")

    p_rw = reset_sub.add_parser("workouts", help="Reset weekly counter")
    p_rw.add_argument("user_id", nargs="?", help="User ID")

    p_rwk = reset_sub.add_parser("week", help="Simulate new week")
    p_rwk.add_argument("user_id", nargs="?", help="User ID")

    # ── chat ─────────────────────────────────────────────────────────
    p_chat = sub.add_parser("chat", help="Chat with Max (Q&A + commands)")
    p_chat.add_argument("user_id", nargs="?", help="User ID")
    p_chat.add_argument("message", help="Message to send")

    return parser


# ── Dispatch ─────────────────────────────────────────────────────────────

DISPATCH = {
    ("health", None): cmd_health,
    ("help", None): cmd_help,
    ("configure", None): cmd_configure,
    ("users", "intake"): cmd_users_intake,
    ("users", "refine"): cmd_users_refine,
    ("users", "accept"): cmd_users_accept,
    ("users", "select"): cmd_users_select,
    ("users", "profile"): cmd_users_profile,
    ("users", "status"): cmd_users_status,
    ("users", "settings"): cmd_users_settings,
    ("workout", "generate"): cmd_workout_generate,
    ("workout", "log-set"): cmd_workout_log_set,
    ("workout", "finish"): cmd_workout_finish,
    ("workout", "history"): cmd_workout_history,
    ("reset", "fatigue"): cmd_reset_fatigue,
    ("reset", "workouts"): cmd_reset_workouts,
    ("reset", "week"): cmd_reset_week,
    ("chat", None): cmd_chat,
}


def main() -> None:
    # Handle --json anywhere in the command (argparse doesn't propagate parent flags to subcommands)
    json_output = "--json" in sys.argv
    if json_output:
        sys.argv.remove("--json")

    parser = build_parser()
    args = parser.parse_args()
    args.json_output = json_output

    if not args.command:
        parser.print_help()
        sys.exit(0)

    action = getattr(args, "action", None)
    key = (args.command, action)

    # For chat, the message is a positional arg, not an action
    if args.command == "chat":
        key = ("chat", None)

    handler = DISPATCH.get(key)
    if not handler:
        if args.command in ("users", "workout", "reset") and not action:
            # Print subcommand help
            parser.parse_args([args.command, "--help"])
        else:
            err_console.print(f"[red]Unknown command:[/red] {args.command} {action or ''}")
        sys.exit(1)

    handler(args)


if __name__ == "__main__":
    main()
